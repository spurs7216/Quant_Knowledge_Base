    },
    {
      "id": "wiki-text",
      "type": "text",
      "x": -1020,
      "y": 60,
      "width": 2060,
      "height": 460,
      "text": "Wiki doctrine\\n\\n- `wiki/` is the durable layer\\n- source notes feed concept, method, dataset, metric, and strategy notes\\n- identifiers anchor joins and lineage\\n- maps route reading and navigation\\n- markdown is the source of truth; Bases and Canvas summarize it\\n- update notes only after reading, understanding, reflecting, and then writing"
    },
    {
      "id": "ops-text",
      "type": "text",
      "x": -1020,
      "y": 780,
      "width": 980,
      "height": 300,
      "text": "Obsidian doctrine\\n\\nLinks -> primary structure\\nBases -> operational dashboards\\nTags -> secondary facets\\nCanvas -> spatial orientation\\nBacklinks/orphans -> lint signals"
    },
    {
      "id": "ops-cli",
      "type": "text",
      "x": 40,
      "y": 780,
      "width": 1000,
      "height": 300,
      "text": "Codex environment note\\n\\n- MCP is the default for note-local maintenance\\n- shell-side `obsidian` CLI needs unsandboxed execution in this setup\\n- use CLI for app-native actions like tabs, commands, Bases, backlink audits, and opening canvas views"
    },
    {
      "id": "project-readme",
      "type": "file",
      "x": 1380,
      "y": -520,
      "width": 420,
      "height": 240,
      "file": "projects/README.md"

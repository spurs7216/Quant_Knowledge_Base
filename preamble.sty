% Quant vault MathJax preamble for Extended MathJax in Obsidian.
% Keep this file conservative: only add macros that are broadly useful
% across math, statistics, optimization, and quant research notes.

% Number systems
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\C}{\mathbb{C}}

% Probability and statistics
\newcommand{\Prob}{\mathbb{P}}
\newcommand{\E}{\mathbb{E}}
\newcommand{\Var}{\operatorname{Var}}
\newcommand{\Cov}{\operatorname{Cov}}
\newcommand{\Corr}{\operatorname{Corr}}
\newcommand{\Bias}{\operatorname{Bias}}
\newcommand{\MSE}{\operatorname{MSE}}
\newcommand{\KL}{\operatorname{KL}}
\newcommand{\iid}{\overset{\mathrm{iid}}{\sim}}
\newcommand{\indep}{\perp\!\!\!\perp}

% Linear algebra and analysis
\newcommand{\tr}{\operatorname{tr}}
\newcommand{\diag}{\operatorname{diag}}
\newcommand{\rank}{\operatorname{rank}}
\newcommand{\spanop}{\operatorname{span}}
\newcommand{\nullspace}{\operatorname{null}}
\newcommand{\range}{\operatorname{range}}
\newcommand{\sign}{\operatorname{sign}}
\newcommand{\trans}{\mathsf{T}}

% Optimization
\newcommand{\argmin}{\mathop{\mathrm{arg\,min}}\limits}
\newcommand{\argmax}{\mathop{\mathrm{arg\,max}}\limits}
\newcommand{\prox}{\operatorname{prox}}
\newcommand{\st}{\text{s.t.}}
\newcommand{\subjectto}{\text{subject to}}

% Common delimiters
\newcommand{\abs}[1]{\left|#1\right|}
\newcommand{\norm}[1]{\left\lVert#1\right\rVert}
\newcommand{\set}[1]{\left\{#1\right\}}
\newcommand{\paren}[1]{\left(#1\right)}
\newcommand{\bracket}[1]{\left[#1\right]}
\newcommand{\inner}[2]{\left\langle #1, #2 \right\rangle}
\newcommand{\given}{\,|\,}
\newcommand{\diff}{\,\mathrm{d}}
\newcommand{\eps}{\varepsilon}

% Frequently used symbols
\newcommand{\ones}{\mathbf{1}}
\newcommand{\zero}{\mathbf{0}}
